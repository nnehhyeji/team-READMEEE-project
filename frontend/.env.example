# [API Endpoint]
# 백엔드 서버 주소 (로컬: http://localhost:8000)
VITE_API_BASE_URL=http://127.0.0.1:8000

# [Supabase Storage]
# 사진 업로드 기능 사용 시 필요 (Supabase 스토리지 설정)
# 만약 설정하지 않으면 로컬 media 폴더에 저장되도록 백엔드가 자동으로 처리합니다.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# [Social Login Keys] (Optional)
# 소셜 로그인 기능 테스트 시 필요 (SDK 초기화용)
# VITE_KAKAO_APP_KEY=your_kakao_app_key